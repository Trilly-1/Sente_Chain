# SenteChain Frontend — copy to .env for local dev
# copy .env.example .env (Windows)

# Backend API URL (local)
VITE_API_URL=http://localhost:8080

# Production builds use .env.production (Vercel picks this up automatically on deploy)

# Demo mode — set false to use real API (production: false)
VITE_USE_DEMO=false

# TESTING ONLY — skip document KYC UI. Set false before pilot.
VITE_SKIP_KYC=true

# Stellar explorer: testnet | mainnet
VITE_STELLAR_NETWORK=testnet
