# SenteChain Backend — copy to .env and fill in your Neon values
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)

# Neon PostgreSQL (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# golang-migrate — Neon pooler needs endpoint option:
# MIGRATIONS_DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/DB?sslmode=require&options=endpoint%3Dep-xxx
MIGRATIONS_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&options=endpoint%3DYOUR_ENDPOINT_ID

# JWT (required, min 32 chars) — generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=24

PORT=8080

# development | production
APP_ENV=development

# CORS — comma-separated frontend origins (production must include your Vercel URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://sentechain.vercel.app

# Auth rate limit (per IP, per window)
AUTH_RATE_LIMIT=20
AUTH_RATE_WINDOW_SEC=60

# Dev only — never true in production (server refuses to start)
EXPOSE_OTP_IN_RESPONSE=false

# Swagger at /docs — auto-disabled when APP_ENV=production unless explicitly true
ENABLE_DOCS=true

# Platform service fee on savings deposits (percent). Recommend 1–2.5; 10% is too high for SACCOs.
PLATFORM_FEE_PERCENT=1.5

# TESTING ONLY — skip member/SACCO document KYC. Set false (or remove) before pilot.
SKIP_KYC=true

# Dev only — expose email verification/reset links in API responses (never true in production)
EXPOSE_EMAIL_LINKS_IN_RESPONSE=false

# ─── Brevo transactional email (registration confirm + PIN reset) ───
# Create API key at https://app.brevo.com/settings/keys/api
# Verify sender domain/email at https://app.brevo.com/senders
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=SenteChain
FRONTEND_URL=http://localhost:5173

# ─── MTN MoMo Collections API (fill when merchant account is approved) ───
# SACCO phone numbers are set per-SACCO in Admin → Payment Settings (not generated by API).
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=UGX
MTN_MOMO_CALLBACK_URL=https://sente-chain.onrender.com/webhooks/mtn/momo
# Optional — when set, MTN callbacks must send matching X-Callback-Signature header
MTN_MOMO_WEBHOOK_SECRET=

# ─── Airtel Money API (fill when merchant account is approved) ───
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CALLBACK_URL=https://sente-chain.onrender.com/webhooks/airtel/money
# Optional — when set, Airtel callbacks must send matching X-Airtel-Signature header
AIRTEL_WEBHOOK_SECRET=

# Webhook routes (no auth — register these URLs with MTN/Airtel):
#   GET  /webhooks/health          — readiness check
#   GET  /webhooks/mtn/momo        — URL verification ping
#   POST /webhooks/mtn/momo        — MTN payment callbacks
#   GET  /webhooks/airtel/money    — URL verification ping
#   POST /webhooks/airtel/money    — Airtel payment callbacks
#   POST /webhooks/test/inbound-payment — dev-only test (APP_ENV != production)

AIRTEL_WEBHOOK_SECRET=

# ─── SenteChain platform admin (applied by migration 000009) ───
PROJECT_ADMIN_PHONE=+256764331334
PROJECT_ADMIN_PIN=0909

# Service fee on member savings (MoMo/web). 1.5 recommended; cap 25 in code.
PLATFORM_FEE_PERCENT=1.5

# Dev seed (migration 000003): project admin +256700000001 PIN 1234, Demo SACCO DEMO01 (UG)

# Stellar anchoring (optional)
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# STELLAR_SOURCE_SECRET=
